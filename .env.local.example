# Copy this file to .env.local and fill in your values

# PostgreSQL — e.g. from Neon, Supabase, Railway, or local
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/portfolio?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (used by the seed script to create the first admin user)
ADMIN_EMAIL="nazmussakibsiraji@gmail.com"
ADMIN_PASSWORD="choose-a-strong-password"
