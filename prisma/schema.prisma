// Prisma schema — Nazmus Sakib Portfolio CMS
// Database: PostgreSQL  |  ORM: Prisma 5.x  |  Auth: NextAuth v4
//
// Sections managed via this schema:
//   Hero · Skills · Services · Experience · Education
//   Projects (Portfolio) · Clients · Stats · User (admin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// NextAuth Required Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // bcrypt-hashed password for credentials provider
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Hero Section — Singleton (always upsert on id "main")
// Manages the animated typing roles and intro paragraph in the Hero component.
// ─────────────────────────────────────────────────────────────────────────────

model HeroConfig {
  // Fixed id so we always upsert the same row
  id            String   @id @default("main")
  // Full display name — shown in the nav logo and hero heading
  fullName      String   @default("Nazmus Sakib Siraji")
  // URL to profile photo — used in the nav logo circle only
  avatarUrl      String?
  // URL to photo shown in the hero section right column (can differ from nav avatar)
  heroImageUrl   String?
  // Cycling roles for the typing animation, e.g.:
  // ["Software Engineer", "Technical Project Manager", "Entrepreneur", "Human Rights Activist"]
  typingTexts    String[]
  // The small badge text above the name
  statusBadge    String   @default("Open to new opportunities")
  // Full intro paragraph (bio summary in the hero)
  introPara      String   @db.Text
  // Primary title line (shown below the name)
  primaryTitle   String   @default("Software Engineer & Technical Project Manager")
  // Company shown on the primary title line
  primaryCompany String   @default("Arbree Limited")
  // Secondary descriptor lines — each entry renders as a separate line below the primary title
  secondaryLines String[]
  // Social / contact links shown in the "Find with me" row
  linkedinUrl    String?
  whatsappNumber String? // E.164 format, e.g. "+8801712345678"
  officeAddress  String? @db.Text
  officeMapUrl   String? // Google Maps link (regular or embed URL)
  // Primary contact email (shown in hero below social links)
  primaryEmail   String? @default("nazmussakibsiraji@gmail.com")
  // Org emails for footer: [{name: string, email: string}]
  orgEmails      Json    @default("[]")
  // Site favicon URL
  faviconUrl     String?
  updatedAt     DateTime @updatedAt

  @@map("hero_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// Password Reset Tokens
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Skill Categories — Dynamic, ordered, coloured
// slug must match Skill.category string value.
// color options: indigo | violet | emerald | rose | blue | amber | cyan | orange
// ─────────────────────────────────────────────────────────────────────────────

model SkillCategory {
  id    String @id @default(cuid())
  name  String
  // Short key used to group skills, e.g. "tech", "pm", "consulting"
  slug  String @unique
  // Tailwind colour name for the column accent
  color String @default("indigo")
  order Int    @default(0)

  @@map("skill_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// Skills — belong to a SkillCategory via the category slug string
// ─────────────────────────────────────────────────────────────────────────────

model Skill {
  id          String @id @default(cuid())
  name        String
  // Must match a SkillCategory.slug value
  category    String
  subcategory String
  order       Int    @default(0)

  @@map("skills")
}

// ─────────────────────────────────────────────────────────────────────────────
// Services — What I Offer
// icon: Lucide icon name string (resolved at render time, e.g. "Briefcase", "Code2")
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  // Display index, e.g. "01"
  number      String
  // Lucide icon name: "Briefcase" | "Code2" | "Megaphone" | "ClipboardList" | "HeartHandshake" | "Server"
  icon        String
  title       String
  description String   @db.Text
  // Display tags, e.g. ["Next.js", "Flutter", "Node.js"]
  tags        String[]
  order       Int      @default(0)

  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// Experience — Work History (Multi-Column Grid in UI)
// The grid layout shows Education on left and Job Experience on right,
// matching the reference image's "My Resume" section.
// ─────────────────────────────────────────────────────────────────────────────

model Experience {
  id          String    @id @default(cuid())
  // Human-readable period string for display, e.g. "Sep 2024 – Present"
  period      String
  // Actual dates for sorting
  startDate   DateTime
  endDate     DateTime?
  role        String
  company     String
  description String    @db.Text
  // Key projects / deliverables as bullet-point strings
  projects    String[]
  // Optional footnote / operational note
  note        String?   @db.Text
  isCurrent   Boolean   @default(false)
  // Lower order = shown first (most recent at top)
  order       Int       @default(0)

  @@map("experiences")
}

// ─────────────────────────────────────────────────────────────────────────────
// Education — Academic Background
// ─────────────────────────────────────────────────────────────────────────────

model Education {
  id          String  @id @default(cuid())
  // Display type label, e.g. "University", "Higher Secondary (HSC)", "Secondary (SSC)"
  type        String
  year        String
  degree      String
  institution String
  // Highlights the card (used for university degree)
  highlight   Boolean @default(false)
  order       Int     @default(0)

  @@map("education")
}

// ─────────────────────────────────────────────────────────────────────────────
// Projects — Portfolio Items (Filterable Grid)
// Filter bar options: All | Technonix | Arbree | Opus | HyperTag | Masleap | Koderden | OproIT
// The `company` field is the primary filter key.
// `tags` are tech/type labels shown on the card.
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  // Full URL to a hosted image (Cloudinary, S3, etc.)
  imageUrl    String?
  liveUrl     String?
  githubUrl   String?
  // Primary filter key — must be one of:
  // "Technonix" | "Arbree" | "Opus" | "HyperTag" | "Masleap" | "Koderden" | "OproIT"
  company     String
  // Tech/type tags shown on the card, e.g. ["Next.js", "PostgreSQL", "SaaS"]
  tags        String[]
  // Pinned to top of grid
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

// ─────────────────────────────────────────────────────────────────────────────
// Clients — Filterable by Company Context
// The `company` field controls which filter tab shows this client.
// e.g. company="Arbree" → visible when "Arbree" tab is active.
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id      String  @id @default(cuid())
  name    String
  // URL to client logo image
  logoUrl String?
  website String?
  // Which portfolio company managed this client relationship:
  // "Arbree" | "Opus" | "HyperTag" | "Masleap" | "Koderden" | "Technonix"
  company String
  order   Int     @default(0)

  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stats — Quick Stats Bar (shown in About / Hero section)
// e.g. { value: "10+", label: "Years Experience" }
// ─────────────────────────────────────────────────────────────────────────────

model Stat {
  id    String @id @default(cuid())
  value String // "10+", "30+", "5+"
  label String // "Years Experience", "Projects Delivered", "Countries"
  order Int    @default(0)

  @@map("stats")
}

// ─────────────────────────────────────────────────────────────────────────────
// About Section — Singleton (always upsert on id "main")
// bio: HTML from TipTap WYSIWYG editor
// cards: JSON array [{icon, label, value}] for the right-column info grid
// ─────────────────────────────────────────────────────────────────────────────

model AboutConfig {
  id       String @id @default("main")
  headline String @default("Bridging technology and strategy")
  bio      String @db.Text
  cvUrl    String?
  // [{id, badge, description, bullets, tags}]
  cards    Json   @default("[]")
  updatedAt DateTime @updatedAt

  @@map("about_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// Training — shown under Education Quality in Resume section
// ─────────────────────────────────────────────────────────────────────────────

model Training {
  id          String  @id @default(cuid())
  title       String
  institution String
  year        String
  description String? @db.Text
  order       Int     @default(0)

  @@map("trainings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Footer Config — Singleton
// ─────────────────────────────────────────────────────────────────────────────

model FooterConfig {
  id           String   @id @default("main")
  tagline      String?  @default("Building technology with purpose.")
  description  String?  @db.Text
  copyrightName String? @default("Nazmus Sakib Siraji")
  // Short designation shown under the name in the footer brand column
  designation  String?  @default("Software Engineer & TPM")
  updatedAt    DateTime @updatedAt

  @@map("footer_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// Testimonials
// ─────────────────────────────────────────────────────────────────────────────

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  designation String
  company     String
  companyUrl  String?
  message     String   @db.Text
  avatarUrl   String?
  isPublic    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────────────────────
// Blog
// ─────────────────────────────────────────────────────────────────────────────

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  body       String        @db.Text
  excerpt    String?       @db.Text
  coverUrl   String?
  imageUrls  String[]
  featured   Boolean       @default(false)
  published  Boolean       @default(true)
  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("blog_posts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Gallery
// ─────────────────────────────────────────────────────────────────────────────

model GalleryPost {
  id        String   @id @default(cuid())
  type      String   @default("photo")  // "photo" | "video"
  caption   String?
  mediaUrls String[]
  videoUrl  String?
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_posts")
}
